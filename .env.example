# Copy this to .env and fill in values. Never commit .env.
#
# NOTE: Ports are no longer configured here.
#   - Docker service ports (MySQL, Redis, Piston) are assigned randomly by Docker
#     and discovered at runtime via `docker compose port`.
#   - App ports (Flask, UI, logging) are allocated as free ports by `slbp server run`
#     and written to .slbp-server.json; use `slbp ui open` to open the browser.

# Redis host (port is discovered automatically via docker compose)
REDIS_HOST=localhost

# Flask secret key -- change this to something random in any real deployment
SECRET_KEY=change-me
